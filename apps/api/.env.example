APP_NAME=School ERP API
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,http://localhost:3001
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/school_erp?schema=public
JWT_SECRET=change_this_to_a_long_secret_with_at_least_32_characters
JWT_EXPIRES_IN=1d
REDIS_URL=redis://localhost:6379
TRUST_PROXY=false
LOG_LEVEL=log,error,warn,debug,verbose
