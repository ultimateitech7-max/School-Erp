generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
  PARENT
  STAFF
  CUSTOM
}

enum UserType {
  ADMIN
  TEACHER
  STAFF
  PARENT
}

enum ModuleCode {
  STUDENTS
  TEACHERS
  ATTENDANCE
  FEES
  EXAMS
  TRANSPORT
  LIBRARY
  COMMUNICATION
  ACADEMICS
}

enum SubjectType {
  THEORY
  PRACTICAL
  ACTIVITY
  LANGUAGE
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum GuardianRelationship {
  FATHER
  MOTHER
  GUARDIAN
  BROTHER
  SISTER
  RELATIVE
  OTHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  ALUMNI
  WITHDRAWN
}

enum AdmissionStatus {
  ACTIVE
  PROMOTED
  TRANSFERRED
  WITHDRAWN
  COMPLETED
}

enum AdmissionApplicationStatus {
  INQUIRY
  APPLIED
  UNDER_REVIEW
  APPROVED
  ENROLLED
  REJECTED
}

enum PromotionAction {
  PROMOTED
  DETAINED
}

enum TeacherStatus {
  ACTIVE
  INACTIVE
  LEFT
}

enum TeacherAssignmentRole {
  CLASS_TEACHER
  SUBJECT_TEACHER
  COORDINATOR
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  LEAVE
  EXCUSED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum FeeCategory {
  TUITION
  ADMISSION
  TRANSPORT
  EXAM
  LIBRARY
  HOSTEL
  OTHER
}

enum FeeFrequency {
  ONE_TIME
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  ANNUAL
}

enum FeeAssignmentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  WAIVED
  CANCELLED
}

enum PaymentMode {
  CASH
  CARD
  BANK_TRANSFER
  UPI
  CHEQUE
  ONLINE
}

enum ExamType {
  UNIT
  MIDTERM
  FINAL
  PRACTICAL
  OTHER
}

enum ExamStatus {
  DRAFT
  SCHEDULED
  ONGOING
  PUBLISHED
  CLOSED
}

enum NoticeAudienceType {
  ALL
  STUDENTS
  PARENTS
  STAFF
}

enum HolidayType {
  HOLIDAY
  EVENT
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  READ
}

enum TransportAssignmentStatus {
  ACTIVE
  INACTIVE
  STOPPED
}

enum CustomFieldType {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTISELECT
  EMAIL
  PHONE
  FILE
}

model School {
  id                    String                 @id @default(uuid()) @db.Uuid
  schoolCode            String                 @unique @map("school_code") @db.VarChar(50)
  name                  String                 @db.VarChar(200)
  subdomain             String                 @unique @db.VarChar(120)
  email                 String?                @db.VarChar(320)
  phone                 String?                @db.VarChar(30)
  timezone              String                 @default("UTC") @db.VarChar(64)
  addressJson           Json                   @default("{}") @map("address_jsonb")
  settingsJson          Json                   @default("{}") @map("settings_jsonb")
  isActive              Boolean                @default(true) @map("is_active")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  roles                 Role[]
  users                 User[]
  schoolModules         SchoolModule[]
  academicSessions      AcademicSession[]
  academicClasses       AcademicClass[]
  sections              Section[]
  subjects              Subject[]
  classSubjects         ClassSubject[]
  students              Student[]
  parents               Parent[]
  parentStudents        ParentStudent[]
  studentGuardians      StudentGuardian[]
  admissions            Admission[]
  admissionApplications AdmissionApplication[]
  promotionHistories    PromotionHistory[]
  studentDocuments      StudentDocument[]
  teachers              Teacher[]
  teacherAssignments    TeacherAssignment[]
  timetableEntries      TimetableEntry[]
  examDateSheets        ExamDateSheet[]
  homeworkItems         Homework[]
  notices               Notice[]
  attendanceRecords     AttendanceRecord[]
  feeStructures         FeeStructure[]
  feeAssignments        FeeAssignment[]
  feePayments           FeePayment[]
  feeReceipts           FeeReceipt[]
  exams                 Exam[]
  examSubjects          ExamSubject[]
  marks                 Mark[]
  reportCards           ReportCard[]
  notifications         Notification[]
  messages              Message[]
  holidays              Holiday[]
  routes                Route[]
  vehicles              Vehicle[]
  transportAssignments  TransportAssignment[]
  customFields          CustomField[]
  customFieldValues     CustomFieldValue[]

  @@index([isActive])
  @@map("schools")
}

model Module {
  id            String         @id @default(uuid()) @db.Uuid
  moduleCode    ModuleCode     @unique @map("module_code")
  moduleName    String         @map("module_name") @db.VarChar(120)
  description   String?
  sortOrder     Int            @default(0) @map("sort_order")
  isCore        Boolean        @default(false) @map("is_core")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  permissions   Permission[]
  schoolModules SchoolModule[]
  customFields  CustomField[]

  @@index([isActive, sortOrder])
  @@map("modules")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  moduleId        String?          @map("module_id") @db.Uuid
  permissionCode  String           @unique @map("permission_code") @db.VarChar(100)
  permissionName  String           @map("permission_name") @db.VarChar(150)
  actionKey       String           @map("action_key") @db.VarChar(50)
  description     String?
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  module          Module?          @relation(fields: [moduleId], references: [id], onDelete: Restrict)
  rolePermissions RolePermission[]

  @@index([moduleId, isActive])
  @@map("permissions")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  schoolId        String?          @map("school_id") @db.Uuid
  scopeKey        String           @default("GLOBAL") @map("scope_key") @db.VarChar(100)
  roleCode        String           @map("role_code") @db.VarChar(80)
  roleName        String           @map("role_name") @db.VarChar(120)
  roleType        RoleType         @default(CUSTOM) @map("role_type")
  description     String?
  isSystem        Boolean          @default(false) @map("is_system")
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  school          School?          @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  users           User[]
  rolePermissions RolePermission[]

  @@unique([scopeKey, roleCode])
  @@index([schoolId, isActive])
  @@map("roles")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model User {
  id                   String             @id @default(uuid()) @db.Uuid
  schoolId             String?            @map("school_id") @db.Uuid
  roleId               String             @map("role_id") @db.Uuid
  fullName             String             @map("full_name") @db.VarChar(200)
  email                String             @unique @db.VarChar(320)
  passwordHash         String             @map("password_hash")
  phone                String?            @db.VarChar(30)
  userType             UserType           @default(ADMIN) @map("user_type")
  designation          String?            @db.VarChar(120)
  isActive             Boolean            @default(true) @map("is_active")
  lastLoginAt          DateTime?          @map("last_login_at")
  passwordChangedAt    DateTime?          @map("password_changed_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  school               School?            @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  role                 Role               @relation(fields: [roleId], references: [id], onDelete: Restrict)
  studentProfile       Student?           @relation("StudentPortalUser")
  teacherProfile       Teacher?           @relation("TeacherPortalUser")
  parentProfile        Parent?            @relation("ParentPortalUser")
  guardianLinks        StudentGuardian[]  @relation("GuardianPortalUser")
  uploadedDocuments    StudentDocument[]  @relation("StudentDocumentUploader")
  markedAttendance     AttendanceRecord[] @relation("AttendanceMarker")
  receivedFeeReceipts  FeeReceipt[]       @relation("FeeReceiptReceiver")
  enteredMarks         Mark[]             @relation("MarksEntryUser")
  recordedPromotions   PromotionHistory[] @relation("PromotionActor")
  generatedReportCards ReportCard[]       @relation("ReportCardGenerator")
  notifications        Notification[]     @relation("NotificationRecipient")
  sentMessages         Message[]          @relation("SentMessages")
  receivedMessages     Message[]          @relation("ReceivedMessages")

  @@index([schoolId, roleId, isActive])
  @@index([schoolId, isActive])
  @@index([schoolId, userType, isActive])
  @@map("users")
}

model SchoolModule {
  id           String    @id @default(uuid()) @db.Uuid
  schoolId     String    @map("school_id") @db.Uuid
  moduleId     String    @map("module_id") @db.Uuid
  enabled      Boolean   @default(true)
  settingsJson Json      @default("{}") @map("settings_jsonb")
  enabledAt    DateTime? @map("enabled_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  module       Module    @relation(fields: [moduleId], references: [id], onDelete: Restrict)

  @@unique([schoolId, moduleId])
  @@index([schoolId, enabled])
  @@map("school_modules")
}

model AcademicSession {
  id                   String                @id @default(uuid()) @db.Uuid
  schoolId             String                @map("school_id") @db.Uuid
  sessionName          String                @map("session_name") @db.VarChar(50)
  startDate            DateTime              @map("start_date") @db.Date
  endDate              DateTime              @map("end_date") @db.Date
  isCurrent            Boolean               @default(false) @map("is_current")
  isActive             Boolean               @default(true) @map("is_active")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  school               School                @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  classSubjects        ClassSubject[]
  admissions           Admission[]
  teacherAssignments   TeacherAssignment[]
  attendanceRecords    AttendanceRecord[]
  feeStructures        FeeStructure[]
  feeAssignments       FeeAssignment[]
  exams                Exam[]
  reportCards          ReportCard[]
  promotionsFrom       PromotionHistory[]    @relation("PromotionFromSession")
  promotionsTo         PromotionHistory[]    @relation("PromotionToSession")
  transportAssignments TransportAssignment[]

  @@unique([schoolId, sessionName])
  @@index([schoolId, isActive])
  @@index([schoolId, isCurrent])
  @@map("sessions")
}

model AcademicClass {
  id                 String              @id @default(uuid()) @db.Uuid
  schoolId           String              @map("school_id") @db.Uuid
  classCode          String              @map("class_code") @db.VarChar(30)
  className          String              @map("class_name") @db.VarChar(100)
  gradeLevel         Int?                @map("grade_level")
  sortOrder          Int                 @default(0) @map("sort_order")
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  school             School              @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  sections           Section[]
  classSubjects      ClassSubject[]
  admissions         Admission[]
  promotionsFrom     PromotionHistory[]  @relation("PromotionFromClass")
  promotionsTo       PromotionHistory[]  @relation("PromotionToClass")
  teacherAssignments TeacherAssignment[]
  timetableEntries   TimetableEntry[]
  attendanceRecords  AttendanceRecord[]
  feeStructures      FeeStructure[]
  exams              Exam[]
  examDateSheets     ExamDateSheet[]
  homeworkItems      Homework[]

  @@unique([schoolId, classCode])
  @@unique([schoolId, className])
  @@index([schoolId, isActive, sortOrder])
  @@map("classes")
}

model Section {
  id                 String              @id @default(uuid()) @db.Uuid
  schoolId           String              @map("school_id") @db.Uuid
  classId            String              @map("class_id") @db.Uuid
  sectionName        String              @map("section_name") @db.VarChar(50)
  roomNo             String?             @map("room_no") @db.VarChar(20)
  capacity           Int?
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  school             School              @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  academicClass      AcademicClass       @relation(fields: [classId], references: [id], onDelete: Restrict)
  admissions         Admission[]
  promotionsFrom     PromotionHistory[]  @relation("PromotionFromSection")
  promotionsTo       PromotionHistory[]  @relation("PromotionToSection")
  teacherAssignments TeacherAssignment[]
  timetableEntries   TimetableEntry[]
  attendanceRecords  AttendanceRecord[]
  homeworkItems      Homework[]

  @@unique([schoolId, classId, sectionName])
  @@index([schoolId, classId, isActive])
  @@map("sections")
}

model Subject {
  id                 String              @id @default(uuid()) @db.Uuid
  schoolId           String              @map("school_id") @db.Uuid
  subjectCode        String              @map("subject_code") @db.VarChar(30)
  subjectName        String              @map("subject_name") @db.VarChar(150)
  subjectType        SubjectType         @default(THEORY) @map("subject_type")
  isOptional         Boolean             @default(false) @map("is_optional")
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  school             School              @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  classSubjects      ClassSubject[]
  teacherAssignments TeacherAssignment[]
  timetableEntries   TimetableEntry[]
  examSubjects       ExamSubject[]
  examDateSheetEntries ExamDateSheetEntry[]
  homeworkItems        Homework[]

  @@unique([schoolId, subjectCode])
  @@index([schoolId, isActive])
  @@map("subjects")
}

model ClassSubject {
  id              String          @id @default(uuid()) @db.Uuid
  schoolId        String          @map("school_id") @db.Uuid
  sessionId       String          @map("session_id") @db.Uuid
  classId         String          @map("class_id") @db.Uuid
  subjectId       String          @map("subject_id") @db.Uuid
  isMandatory     Boolean         @default(true) @map("is_mandatory")
  periodsPerWeek  Int?            @map("periods_per_week")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  school          School          @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  academicSession AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  academicClass   AcademicClass   @relation(fields: [classId], references: [id], onDelete: Restrict)
  subject         Subject         @relation(fields: [subjectId], references: [id], onDelete: Restrict)

  @@unique([schoolId, sessionId, classId, subjectId])
  @@index([schoolId, sessionId, classId])
  @@map("class_subjects")
}

model Student {
  id                    String                 @id @default(uuid()) @db.Uuid
  schoolId              String                 @map("school_id") @db.Uuid
  userId                String?                @unique @map("user_id") @db.Uuid
  studentCode           String                 @map("student_code") @db.VarChar(50)
  registrationNumber    String?                @map("registration_number") @db.VarChar(80)
  firstName             String                 @map("first_name") @db.VarChar(100)
  middleName            String?                @map("middle_name") @db.VarChar(100)
  lastName              String                 @map("last_name") @db.VarChar(100)
  fullName              String                 @map("full_name")
  gender                Gender
  dateOfBirth           DateTime               @map("date_of_birth") @db.Date
  bloodGroup            String?                @map("blood_group") @db.VarChar(5)
  email                 String?                @db.VarChar(320)
  phone                 String?                @db.VarChar(30)
  addressJson           Json                   @default("{}") @map("address_jsonb")
  status                StudentStatus          @default(ACTIVE)
  joinedOn              DateTime?              @map("joined_on") @db.Date
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  school                School                 @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  user                  User?                  @relation("StudentPortalUser", fields: [userId], references: [id], onDelete: SetNull)
  guardians             StudentGuardian[]
  parentLinks           ParentStudent[]
  admissions            Admission[]
  admissionApplications AdmissionApplication[]
  promotionHistories    PromotionHistory[]
  documents             StudentDocument[]
  attendanceRecords     AttendanceRecord[]
  feeAssignments        FeeAssignment[]
  feeReceipts           FeeReceipt[]
  marks                 Mark[]
  reportCards           ReportCard[]
  transportAssignments  TransportAssignment[]

  @@unique([schoolId, studentCode])
  @@unique([schoolId, registrationNumber])
  @@index([schoolId, status])
  @@index([schoolId, dateOfBirth])
  @@index([schoolId, fullName])
  @@index([schoolId, registrationNumber])
  @@map("students")
}

model StudentGuardian {
  id                 String               @id @default(uuid()) @db.Uuid
  schoolId           String               @map("school_id") @db.Uuid
  studentId          String               @map("student_id") @db.Uuid
  userId             String?              @map("user_id") @db.Uuid
  guardianName       String               @map("guardian_name") @db.VarChar(200)
  relationshipType   GuardianRelationship @map("relationship_type")
  mobileNo           String               @map("mobile_no") @db.VarChar(30)
  email              String?              @db.VarChar(320)
  occupation         String?              @db.VarChar(120)
  addressJson        Json                 @default("{}") @map("address_jsonb")
  isPrimary          Boolean              @default(false) @map("is_primary")
  isEmergencyContact Boolean              @default(false) @map("is_emergency_contact")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  school             School               @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  student            Student              @relation(fields: [studentId], references: [id], onDelete: Restrict)
  user               User?                @relation("GuardianPortalUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([schoolId, studentId])
  @@index([studentId, isPrimary])
  @@map("student_guardians")
}

model Parent {
  id                String                @id @default(uuid()) @db.Uuid
  schoolId          String                @map("school_id") @db.Uuid
  userId            String?               @unique @map("user_id") @db.Uuid
  fullName          String                @map("full_name") @db.VarChar(200)
  phone             String                @db.VarChar(30)
  email             String?               @db.VarChar(320)
  address           String?               @db.VarChar(500)
  relationType      GuardianRelationship  @map("relation_type")
  emergencyContact  String?               @map("emergency_contact") @db.VarChar(30)
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  school            School                @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  user              User?                 @relation("ParentPortalUser", fields: [userId], references: [id], onDelete: SetNull)
  parentStudents    ParentStudent[]

  @@index([schoolId, relationType])
  @@index([schoolId, fullName])
  @@index([schoolId, phone])
  @@map("parents")
}

model ParentStudent {
  id            String               @id @default(uuid()) @db.Uuid
  schoolId      String               @map("school_id") @db.Uuid
  parentId      String               @map("parent_id") @db.Uuid
  studentId     String               @map("student_id") @db.Uuid
  relationType  GuardianRelationship @map("relation_type")
  createdAt     DateTime             @default(now()) @map("created_at")
  school        School               @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  parent        Parent               @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student       Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([schoolId, parentId, studentId])
  @@index([schoolId, studentId])
  @@index([schoolId, parentId])
  @@map("parent_students")
}

model Admission {
  id              String             @id @default(uuid()) @db.Uuid
  schoolId        String             @map("school_id") @db.Uuid
  studentId       String             @map("student_id") @db.Uuid
  sessionId       String             @map("session_id") @db.Uuid
  classId         String             @map("class_id") @db.Uuid
  sectionId       String?            @map("section_id") @db.Uuid
  admissionNo     String             @map("admission_no") @db.VarChar(50)
  rollNo          String?            @map("roll_no") @db.VarChar(30)
  admissionDate   DateTime           @map("admission_date") @db.Date
  admissionStatus AdmissionStatus    @default(ACTIVE) @map("admission_status")
  previousSchool  String?            @map("previous_school") @db.VarChar(200)
  remarks         String?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  school          School             @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  student         Student            @relation(fields: [studentId], references: [id], onDelete: Restrict)
  academicSession AcademicSession    @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  academicClass   AcademicClass      @relation(fields: [classId], references: [id], onDelete: Restrict)
  section         Section?           @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  promotionsFrom  PromotionHistory[] @relation("PromotionFromEnrollment")
  promotionsTo    PromotionHistory[] @relation("PromotionToEnrollment")

  @@unique([schoolId, admissionNo])
  @@unique([schoolId, studentId, sessionId])
  @@unique([schoolId, sessionId, sectionId, rollNo])
  @@index([schoolId, sessionId, classId, sectionId, admissionStatus])
  @@map("admissions")
}

model AdmissionApplication {
  id             String                     @id @default(uuid()) @db.Uuid
  schoolId       String                     @map("school_id") @db.Uuid
  studentId      String?                    @map("student_id") @db.Uuid
  studentName    String                     @map("student_name") @db.VarChar(200)
  fatherName     String                     @map("father_name") @db.VarChar(200)
  motherName     String                     @map("mother_name") @db.VarChar(200)
  phone          String                     @db.VarChar(30)
  email          String?                    @db.VarChar(320)
  address        String                     @db.VarChar(500)
  classApplied   String                     @map("class_applied") @db.VarChar(100)
  previousSchool String?                    @map("previous_school") @db.VarChar(200)
  dob            DateTime                   @db.Date
  status         AdmissionApplicationStatus @default(INQUIRY)
  remarks        String?
  createdAt      DateTime                   @default(now()) @map("created_at")
  updatedAt      DateTime                   @updatedAt @map("updated_at")
  school         School                     @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  student        Student?                   @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@index([schoolId, status, createdAt])
  @@index([schoolId, studentName])
  @@index([schoolId, phone])
  @@index([schoolId, studentId])
  @@map("admission_applications")
}

model StudentDocument {
  id               String    @id @default(uuid()) @db.Uuid
  schoolId         String    @map("school_id") @db.Uuid
  studentId        String    @map("student_id") @db.Uuid
  uploadedByUserId String?   @map("uploaded_by_user_id") @db.Uuid
  documentType     String    @map("document_type") @db.VarChar(50)
  documentName     String    @map("document_name") @db.VarChar(150)
  storageKey       String    @map("storage_key")
  mimeType         String?   @map("mime_type") @db.VarChar(100)
