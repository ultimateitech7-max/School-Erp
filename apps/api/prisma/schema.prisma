  recipientUser   User      @relation("ReceivedMessages", fields: [recipientUserId], references: [id], onDelete: Restrict)

  @@index([schoolId, recipientUserId, isRead, createdAt])
  @@index([schoolId, senderUserId, createdAt])
  @@map("messages")
}

model Holiday {
  id        String      @id @default(uuid()) @db.Uuid
  schoolId  String      @map("school_id") @db.Uuid
  title     String      @db.VarChar(200)
  startDate DateTime    @map("start_date") @db.Date
  endDate   DateTime    @map("end_date") @db.Date
  type      HolidayType
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  school    School      @relation(fields: [schoolId], references: [id], onDelete: Restrict)

  @@index([schoolId, startDate, endDate])
  @@index([schoolId, type, startDate])
  @@map("holidays")
}

model Route {
  id                   String                @id @default(uuid()) @db.Uuid
  schoolId             String                @map("school_id") @db.Uuid
  routeCode            String                @map("route_code") @db.VarChar(50)
  routeName            String                @map("route_name") @db.VarChar(150)
  startPoint           String                @map("start_point") @db.VarChar(150)
  endPoint             String                @map("end_point") @db.VarChar(150)
  distanceKm           Decimal?              @map("distance_km") @db.Decimal(8, 2)
  monthlyFee           Decimal               @default(0) @map("monthly_fee") @db.Decimal(12, 2)
  isActive             Boolean               @default(true) @map("is_active")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  school               School                @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  transportAssignments TransportAssignment[]

  @@unique([schoolId, routeCode])
  @@index([schoolId, isActive])
  @@map("routes")
}

model Vehicle {
  id                   String                @id @default(uuid()) @db.Uuid
  schoolId             String                @map("school_id") @db.Uuid
  vehicleNumber        String                @map("vehicle_number") @db.VarChar(50)
  vehicleType          String?               @map("vehicle_type") @db.VarChar(30)
  capacity             Int
  driverName           String?               @map("driver_name") @db.VarChar(150)
  driverPhone          String?               @map("driver_phone") @db.VarChar(30)
  attendantName        String?               @map("attendant_name") @db.VarChar(150)
  isActive             Boolean               @default(true) @map("is_active")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  school               School                @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  transportAssignments TransportAssignment[]

  @@unique([schoolId, vehicleNumber])
  @@index([schoolId, isActive])
  @@map("vehicles")
}

model TransportAssignment {
  id                 String                    @id @default(uuid()) @db.Uuid
  schoolId           String                    @map("school_id") @db.Uuid
  sessionId          String                    @map("session_id") @db.Uuid
  studentId          String                    @map("student_id") @db.Uuid
  routeId            String                    @map("route_id") @db.Uuid
  vehicleId          String?                   @map("vehicle_id") @db.Uuid
  pickupPoint        String?                   @map("pickup_point") @db.VarChar(150)
  dropPoint          String?                   @map("drop_point") @db.VarChar(150)
  monthlyFeeOverride Decimal?                  @map("monthly_fee_override") @db.Decimal(12, 2)
  startDate          DateTime                  @map("start_date") @db.Date
  endDate            DateTime?                 @map("end_date") @db.Date
  status             TransportAssignmentStatus @default(ACTIVE)
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")
  school             School                    @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  academicSession    AcademicSession           @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  student            Student                   @relation(fields: [studentId], references: [id], onDelete: Restrict)
  route              Route                     @relation(fields: [routeId], references: [id], onDelete: Restrict)
  vehicle            Vehicle?                  @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  @@unique([schoolId, sessionId, studentId, status])
  @@index([schoolId, studentId, sessionId, status])
  @@map("transport_assignments")
}

model CustomField {
  id               String             @id @default(uuid()) @db.Uuid
  schoolId         String             @map("school_id") @db.Uuid
  moduleId         String             @map("module_id") @db.Uuid
  entityName       String             @map("entity_name") @db.VarChar(50)
  fieldKey         String             @map("field_key") @db.VarChar(80)
  fieldLabel       String             @map("field_label") @db.VarChar(150)
  fieldType        CustomFieldType    @map("field_type")
  placeholderText  String?            @map("placeholder_text") @db.VarChar(200)
  optionsJson      Json               @default("[]") @map("options_jsonb")
  validationJson   Json               @default("{}") @map("validation_jsonb")
  defaultValueJson Json?              @map("default_value_jsonb")
  isRequired       Boolean            @default(false) @map("is_required")
  sortOrder        Int                @default(0) @map("sort_order")
  isActive         Boolean            @default(true) @map("is_active")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  school           School             @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  module           Module             @relation(fields: [moduleId], references: [id], onDelete: Restrict)
  values           CustomFieldValue[]

  @@unique([schoolId, entityName, fieldKey])
  @@index([schoolId, entityName, isActive, sortOrder])
  @@map("custom_fields")
}

model CustomFieldValue {
  id            String      @id @default(uuid()) @db.Uuid
  schoolId      String      @map("school_id") @db.Uuid
  customFieldId String      @map("custom_field_id") @db.Uuid
  entityName    String      @map("entity_name") @db.VarChar(50)
  entityId      String      @map("entity_id") @db.Uuid
  valueText     String?     @map("value_text")
  valueNumber   Decimal?    @map("value_number") @db.Decimal(18, 4)
  valueBoolean  Boolean?    @map("value_boolean")
  valueDate     DateTime?   @map("value_date") @db.Date
  valueJson     Json?       @map("value_jsonb")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  school        School      @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([schoolId, customFieldId, entityName, entityId])
  @@index([schoolId, entityName, entityId])
  @@index([schoolId, customFieldId])
  @@map("custom_field_values")
}
